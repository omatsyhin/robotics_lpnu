<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rtr_manipulator">

  <!-- ================= PARAMETERS ================= -->
  <xacro:property name="l2" value="0.9"/>
  <xacro:property name="l3" value="1.0"/>
  <xacro:property name="width" value="0.08"/>

  <xacro:property name="base_radius" value="0.12"/>
  <xacro:property name="base_height" value="0.10"/>

  <xacro:property name="yaw_radius" value="0.06"/>
  <xacro:property name="yaw_height" value="0.30"/>

  <xacro:property name="tool_radius" value="0.03"/>
  <xacro:property name="tool_length" value="0.12"/>

  <!-- ================= MATERIALS ================= -->
  <material name="blue"><color rgba="0 0 1 1"/></material>
  <material name="red"><color rgba="1 0 0 1"/></material>
  <material name="green"><color rgba="0 1 0 1"/></material>
  <material name="grey"><color rgba="0.7 0.7 0.7 1"/></material>

  <!-- ================= MACROS ================= -->

  <xacro:macro name="box_link" params="name size_x size_y size_z origin_x origin_y origin_z mass material_name">
    <link name="${name}">
      <inertial>
        <origin xyz="${origin_x} ${origin_y} ${origin_z}" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
      </inertial>

      <visual>
        <origin xyz="${origin_x} ${origin_y} ${origin_z}" rpy="0 0 0"/>
        <geometry>
          <box size="${size_x} ${size_y} ${size_z}"/>
        </geometry>
        <material name="${material_name}"/>
      </visual>

      <collision>
        <origin xyz="${origin_x} ${origin_y} ${origin_z}" rpy="0 0 0"/>
        <geometry>
          <box size="${size_x} ${size_y} ${size_z}"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="cylinder_link" params="name radius length origin_x origin_y origin_z mass material_name">
    <link name="${name}">
      <inertial>
        <origin xyz="${origin_x} ${origin_y} ${origin_z}" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
      </inertial>

      <visual>
        <origin xyz="${origin_x} ${origin_y} ${origin_z}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
        <material name="${material_name}"/>
      </visual>

      <collision>
        <origin xyz="${origin_x} ${origin_y} ${origin_z}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- ================= LINKS ================= -->

  <link name="world"/>

  <xacro:cylinder_link
    name="base_link"
    radius="${base_radius}"
    length="${base_height}"
    origin_x="0" origin_y="0" origin_z="${base_height/2}"
    mass="5"
    material_name="grey"/>

  <xacro:cylinder_link
    name="link_yaw"
    radius="${yaw_radius}"
    length="${yaw_height}"
    origin_x="0" origin_y="0" origin_z="${yaw_height/2}"
    mass="2"
    material_name="blue"/>

  <xacro:box_link
    name="link_carriage"
    size_x="${width}" size_y="${width}" size_z="${width}"
    origin_x="0" origin_y="0" origin_z="0"
    mass="1"
    material_name="green"/>

  <xacro:box_link
    name="link_upper"
    size_x="${l2}" size_y="${width}" size_z="${width}"
    origin_x="${l2/2}" origin_y="0" origin_z="0"
    mass="10"
    material_name="red"/>

  <xacro:box_link
    name="link_forearm"
    size_x="${l3}" size_y="${width}" size_z="${width}"
    origin_x="${l3/2}" origin_y="0" origin_z="0"
    mass="10"
    material_name="blue"/>

  <link name="tool0">
    <visual>
      <origin xyz="${tool_length/2} 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="${tool_radius}" length="${tool_length}"/>
      </geometry>
      <material name="green"/>
    </visual>

    <collision>
      <origin xyz="${tool_length/2} 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="${tool_radius}" length="${tool_length}"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= JOINTS ================= -->

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint_theta1" type="revolute">
    <parent link="base_link"/>
    <child link="link_yaw"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1.0"/>
  </joint>

  <joint name="joint_theta2" type="prismatic">
    <parent link="link_yaw"/>
    <child link="link_carriage"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="2.0" effort="200" velocity="0.25"/>
  </joint>

  <joint name="fixed_carriage_upper" type="fixed">
    <parent link="link_carriage"/>
    <child link="link_upper"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint_theta3" type="revolute">
    <parent link="link_upper"/>
    <child link="link_forearm"/>
    <origin xyz="${l2} 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1.0"/>
  </joint>

  <joint name="wrist_to_tool0" type="fixed">
    <parent link="link_forearm"/>
    <child link="tool0"/>
    <origin xyz="${l3} 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ================= ROS2 CONTROL ================= -->

  <ros2_control name="RTRMock" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
      <param name="fake_sensor_commands">false</param>
    </hardware>

    <joint name="joint_theta1">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>

    <joint name="joint_theta2">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.5</param>
      </state_interface>
    </joint>

    <joint name="joint_theta3">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.2</param>
      </state_interface>
    </joint>
  </ros2_control>

</robot>